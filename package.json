  "devDependencies": {
    "@types/cheerio": "^0.22.23",
    "@types/cron": "^1.7.2",
    "@types/he": "^1.1.1",
    "@types/lru-cache": "^5.1.0",
    "@types/mathjs": "^6.0.9",
    "@types/moment-timezone": "^0.5.30",
    "@types/mongodb": "^3.6.3",
    "@types/node": "^14.14.20",
    "@types/tz-lookup": "^6.1.0",
    "@typescript-eslint/eslint-plugin": "^4.12.0",
    "@typescript-eslint/parser": "^4.12.0",
    "eslint": "^7.17.0",
